<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <RootNamespace>Serilog.Sinks.Ameto</RootNamespace>
    <AssemblyName>Serilog.Sinks.Ameto</AssemblyName>

    <!-- NuGet metadata -->
    <PackageId>Serilog.Sinks.Ameto</PackageId>
    <Version>0.1.0</Version>
    <Authors>Ameto</Authors>
    <Description>Serilog sink that ships events to an Ameto server (Seq-compatible CLEF over MessagePack).</Description>
    <PackageTags>serilog;sink;logging;ameto;seq;clef</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MessagePack" Version="3.1.7" />
    <PackageReference Include="Serilog" Version="4.2.0" />
    <PackageReference Include="Serilog.Sinks.PeriodicBatching" Version="5.0.0" />
  </ItemGroup>

</Project>
